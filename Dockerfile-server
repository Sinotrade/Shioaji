FROM debian:12-slim AS download

ARG TARGETARCH

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && case "${TARGETARCH:-amd64}" in \
         amd64) ARCH=x86_64 ;; \
         arm64) ARCH=aarch64 ;; \
         *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
       esac \
    && curl -fsSL "https://github.com/sinotrade/shioaji/releases/download/v1.5.0/shioaji-v1.5.0-Linux-${ARCH}.tar.gz" \
       | tar -xz -C /usr/local/bin \
    && chmod +x /usr/local/bin/shioaji

FROM debian:12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=download /usr/local/bin/shioaji /usr/local/bin/shioaji

ENV SJ_HTTP_ADDR=0.0.0.0:8080
EXPOSE 8080

ENTRYPOINT ["shioaji", "server", "start", "--no-open"]
